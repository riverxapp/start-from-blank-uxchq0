#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/tmp/riverx-workspaces/ws_8a1c7b97-cd7/node_modules/.pnpm/skills@1.5.19/node_modules/skills/bin/node_modules:/tmp/riverx-workspaces/ws_8a1c7b97-cd7/node_modules/.pnpm/skills@1.5.19/node_modules/skills/node_modules:/tmp/riverx-workspaces/ws_8a1c7b97-cd7/node_modules/.pnpm/skills@1.5.19/node_modules:/tmp/riverx-workspaces/ws_8a1c7b97-cd7/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/tmp/riverx-workspaces/ws_8a1c7b97-cd7/node_modules/.pnpm/skills@1.5.19/node_modules/skills/bin/node_modules:/tmp/riverx-workspaces/ws_8a1c7b97-cd7/node_modules/.pnpm/skills@1.5.19/node_modules/skills/node_modules:/tmp/riverx-workspaces/ws_8a1c7b97-cd7/node_modules/.pnpm/skills@1.5.19/node_modules:/tmp/riverx-workspaces/ws_8a1c7b97-cd7/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../bin/cli.mjs" "$@"
else
  exec node  "$basedir/../../bin/cli.mjs" "$@"
fi
